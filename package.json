{
  "name": "tonepilot-local",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "concurrently -n backend,desktop \"pnpm backend:dev\" \"pnpm desktop:dev\"",
    "backend:dev": "cd apps/backend && python -m uvicorn app.main:app --reload --port 8765",
    "backend:test": "cd apps/backend && pytest",
    "desktop:dev": "pnpm --filter @tonepilot/desktop dev",
    "desktop:build": "pnpm --filter @tonepilot/desktop build"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
